  end
  
  def show_element_examples
    sample_elements = [
      'button', 'message', 'header', 'table', 'list', 'menu', 
      'segment', 'card', 'form', 'input', 'label', 'icon'
    ].sample(6)
    
    puts <<~EXAMPLES
      
      \e[1;36m╔══════════════════════════════════════════════════════════╗
      ║               Element Examples (Try These!)              ║
      ╚══════════════════════════════════════════════════════════╝\e[0m
      
    EXAMPLES
    
    sample_elements.each do |element|
      examples = get_element_examples(element)
      puts "\e[1;32m#{element.capitalize} Examples:\e[0m"
      
      examples.each do |shorthand, longhand|
        puts "  \e[35m#{shorthand}\e[0m"
        puts "  \e[36m#{longhand}\e[0m"
        puts
      end
    end
    
    puts "\e[33mTip:\e[0m Copy and paste these examples to test them!"
    puts
  end
  

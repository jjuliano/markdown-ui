                                                │  \e[36m> Click Me\e[0m
      
      \e[35m__Success Message|Hello World!__\e[0m        │  \e[36m> Success Message:\e[0m  
                                                │  \e[36m> Hello World!\e[0m
      
      \e[35m__Large Header|Welcome__\e[0m                │  \e[36m> Large Header:\e[0m
                                                │  \e[36m> Welcome\e[0m
      
      \e[35m__Striped Table|Name,Age|John,25__\e[0m      │  \e[36m> Striped Table:\e[0m
